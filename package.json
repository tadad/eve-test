{
  "name": "eve-slack-demo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "pnpm --dir packages/eve-channel-agentmail build && eve build",
    "dev": "pnpm --dir packages/eve-channel-agentmail build && eve dev",
    "start": "eve start",
    "typecheck": "pnpm --dir packages/eve-channel-agentmail typecheck && tsgo",
    "deploy": "vercel deploy --prod --yes"
  },
  "dependencies": {
    "@vercel/connect": "^0.2.5",
    "agentmail": "^0.5.12",
    "ai": "7.0.0-beta.178",
    "eve": "^0.11.6",
    "eve-channel-agentmail": "workspace:*",
    "svix": "^1.96.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "microsandbox": "0.5.7"
  },
  "pnpm": {
    "patchedDependencies": {
      "eve@0.11.6": "patches/eve@0.11.6.patch"
    }
  }
}
