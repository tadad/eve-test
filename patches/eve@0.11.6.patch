+        if (response.ok !== true) {
+          throw Error(`Slack chat.postEphemeral failed: ${response.error ?? `unknown_error`}`);
+        }
+        return {
+          id: typeof response.message_ts === `string` ? response.message_ts : ``,
+          raw: response,
+        };
+      },
+      async postDirectMessage(userId, message) {
+        const openResponse = await request(`conversations.open`, { users: userId });
+        const channelId = openResponse.ok === true ? openResponse.channel?.id : undefined;
+        if (typeof channelId !== `string` || channelId.length === 0) {
+          throw Error(
+            `Slack conversations.open failed: ${openResponse.error ?? `unknown_error`}`,
+          );
+        }
+        const response = await request(
+          `chat.postMessage`,
+          buildPostMessageBody(normalizePostInput(message), channelId, ``),
+        );
+        if (response.ok !== true) {
+          throw Error(`Slack chat.postMessage failed: ${response.error ?? `unknown_error`}`);
+        }
+        return { id: typeof response.ts === `string` ? response.ts : ``, raw: response };
+      },
+      async startTyping(status) {
+        if (!input.channelId || !threadTs) return;
+        try {
+          const body = {
+            channel_id: input.channelId,
+            thread_ts: threadTs,
+            status: status ?? ``,
+          };
+          if (status !== undefined && status.length > 0) body.loading_messages = [status];
+          const response = await request(`assistant.threads.setStatus`, body);
+          if (response.ok !== true) {
+            log.warn(`assistant.threads.setStatus returned not-ok`, {
+              error: response.error,
+            });
+          }
+        } catch (error) {
+          logError(log, `startTyping threw - swallowed`, error, {
+            channelId: input.channelId,
+          });
+        }
+      },
+      async refresh() {
+        recentMessages.length = 0;
+        if (!input.channelId || !threadTs) return;
+        try {
+          const response = await request(`conversations.replies`, {
+            channel: input.channelId,
+            ts: threadTs,
+            limit: 50,
+          });
+          if (response.ok !== true || !Array.isArray(response.messages)) {
+            log.warn(`conversations.replies returned not-ok`, { error: response.error });
+            return;
+          }
+          for (const message of response.messages) {
+            recentMessages.push(parseThreadMessage(message, threadTs));
+          }
+        } catch (error) {
+          logError(log, `refresh threw - swallowed`, error, {
+            channelId: input.channelId,
+          });
+        }
+      },
+      mentionUser(userId) {
+        return `<@${userId}>`;
+      },
+    },
+    slack: {
+      channelId: input.channelId,
+      get threadTs() {
+        return threadTs;
+      },
+      teamId: input.teamId,
+      request,
+      uploadFiles,
+    },
+  };
+}
+
+function normalizePostInput(input) {
+  return typeof input === `string`
+    ? { markdown: input }
+    : isCardElement(input)
+      ? { card: input }
+      : input;
+}
+
+function buildPostMessageBody(input, channelId, threadTs) {
+  const body = {
+    channel: channelId,
+    unfurl_links: false,
+    unfurl_media: false,
+  };
+  if (threadTs) body.thread_ts = threadTs;
+
+  if (`card` in input) {
+    body.blocks = cardToBlocks(input.card);
+    body.text = input.fallbackText ?? cardToFallbackText(input.card);
+    return body;
+  }
+  if (`blocks` in input) {
+    body.blocks = input.blocks;
+    if (input.text !== undefined) body.text = input.text;
+    return body;
+  }
+  if (`markdown` in input) {
+    body.markdown_text = rewriteBareMentions(input.markdown);
+    return body;
+  }
+
+  body.text = rewriteBareMentions(input.text);
+  return body;
+}
+
+function parseThreadMessage(message, fallbackThreadTs) {
+  const text = typeof message.text === `string` ? message.text : ``;
+  const ts = typeof message.ts === `string` ? message.ts : ``;
+  const threadTs =
+    typeof message.thread_ts === `string` ? message.thread_ts : fallbackThreadTs;
+  const user = typeof message.user === `string` ? message.user : undefined;
+  const botId = typeof message.bot_id === `string` ? message.bot_id : undefined;
+  return {
+    text,
+    markdown: slackMrkdwnToGfm(text),
+    user,
+    botId,
+    ts,
+    threadTs,
+    isMe: botId !== undefined,
+    raw: message,
+  };
+}
+
+async function readFileBytes(input) {
+  if (input instanceof ArrayBuffer) return Buffer.from(input);
+  if (typeof Blob !== `undefined` && input instanceof Blob) {
+    return Buffer.from(await input.arrayBuffer());
+  }
+  if (ArrayBuffer.isView(input)) {
+    return Buffer.from(input.buffer, input.byteOffset, input.byteLength);
+  }
+  throw Error(`FileUpload.data must be a Buffer, ArrayBuffer, or Blob.`);
+}
+
+export {
+  buildSlackBinding,
+  callSlackApi,
+  createSlackBotTokenContext,
+  resolveSlackBotToken,
+  slackContinuationToken,
+};
