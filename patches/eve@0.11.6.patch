+import { createLogger } from "#internal/logging.js";
+import {
+  buildSlackBinding,
+  createSlackBotTokenContext,
+  resolveSlackBotToken,
+  slackContinuationToken,
+} from "#public/channels/slack/api.js";
+import { buildSlackAuthContext } from "#public/channels/slack/auth.js";
+import {
+  HITL_FREEFORM_MODAL_ACTION_ID,
+  HITL_FREEFORM_MODAL_BLOCK_ID,
+  HITL_FREEFORM_MODAL_CALLBACK_ID,
+  buildAnsweredBlocks,
+  buildFreeformModalView,
+  deriveHitlResponse,
+  freeformRequestIdFromActionId,
+  isFreeformAction,
+  isHitlAction,
+} from "#public/channels/slack/hitl.js";
+
+const log = createLogger(`slack.interactions`);
+
+function parseBlockActionsPayload(payload) {
+  const actions = payload.actions;
+  if (!Array.isArray(actions)) return null;
+
+  const channelId = payload.channel?.id;
+  const message = payload.message;
+  const threadTs = message?.thread_ts ?? message?.ts;
+  if (!channelId || !threadTs) return null;
+
+  const team = payload.team;
+  const user = payload.user;
+  const teamId = team?.id ?? user.team_id;
+  const interactionUser = {
+    id: user.id,
+    username: user.username,
+    name: user.name,
+  };
+  const messageBlocks = message?.blocks ?? [];
+
+  return {
+    actions: actions.map((action) => ({
+      actionId: String(action.action_id ?? ``),
+      value: action.value == null ? undefined : String(action.value),
+      blockId: action.block_id == null ? undefined : String(action.block_id),
+      selectedOptionValue: extractSelectedOptionValue(action),
+      messageTs: message?.ts,
+      label: extractActionLabel(action),
+      user: interactionUser,
+    })),
+    channelId,
+    threadTs,
+    teamId,
+    messageBlocks,
+  };
+}
+
+function extractSelectedOptionValue(action) {
+  const selectedOption = action.selected_option;
+  return typeof selectedOption?.value === `string` ? selectedOption.value : undefined;
+}
+
+function extractActionLabel(action) {
+  const selectedOptionText = action.selected_option?.text?.text;
+  if (typeof selectedOptionText === `string` && selectedOptionText.length > 0) {
+    return selectedOptionText;
+  }
+  const buttonText = action.text?.text;
+  if (typeof buttonText === `string` && buttonText.length > 0) return buttonText;
+}
+
+function findPromptBlock(blocks) {
+  for (const block of blocks) {
+    if (typeof block === `object` && block && block.type === `section`) return block;
+  }
+}
+
+function readPromptTextFromBlocks(blocks) {
+  const prompt = findPromptBlock(blocks)?.text?.text;
+  return typeof prompt === `string` && prompt.length > 0 ? prompt : undefined;
+}
+
+async function handleInteractionPost(body, runtime, deps) {
+  const response = new Response(`ok`, { status: 200 });
+  const encodedPayload = new URLSearchParams(body).get(`payload`);
+  if (!encodedPayload) return response;
+
+  let payload;
+  try {
+    payload = JSON.parse(encodedPayload);
+  } catch {
+    log.warn(`failed to parse Slack interaction payload`);
+    return response;
+  }
+
+  if (payload?.type === `view_submission`) {
+    return handleViewSubmission(payload, runtime, deps);
+  }
+
+  const interaction = parseBlockActionsPayload(payload);
+  if (!interaction) return response;
+
+  const freeformAction = interaction.actions.find((action) =>
+    isFreeformAction(action.actionId),
+  );
+  if (freeformAction) {
+    await openFreeformModal({
+      payload,
+      interaction,
+      freeformAction,
+      deps,
+    });
+    return response;
+  }
+
+  const continuationToken = slackContinuationToken(
+    interaction.channelId,
+    interaction.threadTs,
+  );
+  const hitlResponses = interaction.actions.map(deriveHitlResponse).filter(Boolean);
+
+  if (hitlResponses.length > 0) {
+    const user = interaction.actions[0]?.user;
+    if (!user) return response;
+
+    runtime.waitUntil(
+      runtime
+        .send(
+          { inputResponses: hitlResponses },
+          {
+            auth: buildSlackAuthContext({
+              channelId: interaction.channelId,
+              teamId: interaction.teamId,
+              threadTs: interaction.threadTs,
+              userId: user.id,
+              userName: user.username ?? user.name,
+            }),
+            continuationToken,
+            state: {
+              channelId: interaction.channelId,
+              threadTs: interaction.threadTs,
+              teamId: interaction.teamId ?? null,
+              triggeringUserId: user.id,
+            },
+          },
+        )
+        .catch((error) => {
+          log.error(`HITL interaction delivery failed`, { error });
+        }),
+    );
+    runtime.waitUntil(
+      updateAnsweredHitlCard(interaction, deps).catch((error) => {
+        log.error(`HITL answered-card update failed`, { error });
+      }),
+    );
+  }
+
+  const onInteraction = deps.config.onInteraction;
+  if (onInteraction) {
+    const customActions = interaction.actions.filter(
+      (action) => !isHitlAction(action.actionId),
+    );
+    if (customActions.length > 0) {
+      const { thread, slack } = buildSlackBinding({
+        botToken: deps.config.credentials?.botToken,
+        channelId: interaction.channelId,
+        threadTs: interaction.threadTs,
+        teamId: interaction.teamId,
+      });
+      const context = { thread, slack };
+      for (const action of customActions) {
+        runtime.waitUntil(
+          Promise.resolve(onInteraction(action, context)).catch((error) => {
+            log.error(`custom interaction handler failed`, { error });
+          }),
+        );
+      }
+    }
+  }
+
+  return response;
+}
+
+async function openFreeformModal(input) {
+  const triggerId = input.payload.trigger_id;
+  if (typeof triggerId !== `string` || triggerId.length === 0) {
+    log.warn(`freeform button click missing trigger_id - cannot open modal`);
+    return;
+  }
+
+  const requestId =
+    freeformRequestIdFromActionId(input.freeformAction.actionId) ??
+    input.freeformAction.value;
+  if (!requestId) {
+    log.warn(`freeform button click missing requestId`);
+    return;
+  }
+
+  const messageTs = input.freeformAction.messageTs;
+  if (!messageTs) {
+    log.warn(`freeform button click missing messageTs`);
+    return;
+  }
+
+  const view = buildFreeformModalView({
+    metadata: {
+      continuationToken: slackContinuationToken(
+        input.interaction.channelId,
+        input.interaction.threadTs,
+      ),
+      channelId: input.interaction.channelId,
+      threadTs: input.interaction.threadTs,
+      teamId: input.interaction.teamId,
+      messageTs,
+      requestId,
+    },
+    prompt: readPromptTextFromBlocks(input.interaction.messageBlocks),
+  });
+
+  const token = await resolveSlackBotToken(
+    input.deps.config.credentials?.botToken,
+    createSlackBotTokenContext({
+      channelId: input.interaction.channelId,
+      threadTs: input.interaction.threadTs,
+      teamId: input.interaction.teamId,
+    }),
+  );
+  const response = await fetch(`https://slack.com/api/views.open`, {
+    method: `POST`,
+    headers: {
+      authorization: `Bearer ${token}`,
+      "content-type": `application/json; charset=utf-8`,
+    },
+    body: JSON.stringify({ trigger_id: triggerId, view }),
+  });
+  if (!response.ok) {
+    log.error(`Slack views.open returned non-2xx`, { status: response.status });
+  }
+}
+
+async function handleViewSubmission(payload, runtime, deps) {
+  const response = new Response(`ok`, { status: 200 });
+  const view = payload.view;
+  if (view?.callback_id !== HITL_FREEFORM_MODAL_CALLBACK_ID) return response;
+
+  let metadata;
+  try {
+    metadata = JSON.parse(view.private_metadata ?? ``);
+  } catch {
+    log.warn(`freeform view_submission carries invalid private_metadata`);
+    return response;
+  }
+
+  if (
+    !metadata.continuationToken ||
+    !metadata.requestId ||
+    !metadata.messageTs ||
+    !metadata.channelId ||
+    !metadata.threadTs
+  ) {
+    return response;
+  }
+
+  const answer =
+    view.state?.values?.[HITL_FREEFORM_MODAL_BLOCK_ID]?.[
+      HITL_FREEFORM_MODAL_ACTION_ID
+    ]?.value;
+  const text = typeof answer === `string` ? answer : ``;
+  if (text.length === 0) return response;
+
+  const team = payload.team;
+  const user = payload.user;
+  const userId = user.id;
+  const teamId = metadata.teamId ?? user.team_id ?? team?.id ?? null;
+
+  runtime.waitUntil(
+    runtime
+      .send(
+        { inputResponses: [{ requestId: metadata.requestId, text }] },
+        {
+          auth: buildSlackAuthContext({
+            channelId: metadata.channelId,
+            teamId,
+            threadTs: metadata.threadTs,
+            userId,
+            userName: user.username ?? user.name,
+          }),
+          continuationToken: metadata.continuationToken,
+          state: {
+            channelId: metadata.channelId,
+            threadTs: metadata.threadTs,
+            teamId,
+            triggeringUserId: userId,
+          },
+        },
+      )
+      .catch((error) => {
+        log.error(`freeform answer delivery failed`, { error });
+      }),
+  );
+  runtime.waitUntil(
+    updateAnsweredFreeformCard({
+      channelId: metadata.channelId,
+      threadTs: metadata.threadTs,
+      teamId,
+      messageTs: metadata.messageTs,
+      answerLabel: text,
+      userId: userId ?? undefined,
+      deps,
+    }).catch((error) => {
+      log.error(`freeform answered-card update failed`, { error });
+    }),
+  );
+
+  return response;
+}
+
+async function updateAnsweredHitlCard(interaction, deps) {
+  const action = interaction.actions.find((action) => isHitlAction(action.actionId));
+  if (!action || !action.messageTs) return;
+
+  const answerLabel = action.label ?? action.selectedOptionValue ?? action.value;
+  if (!answerLabel) return;
+
+  const blocks = buildAnsweredBlocks({
+    promptBlock: findPromptBlock(interaction.messageBlocks),
+    answerLabel,
+    userId: action.user.id,
+  });
+  const token = await resolveSlackBotToken(
+    deps.config.credentials?.botToken,
+    createSlackBotTokenContext({
+      channelId: interaction.channelId,
+      threadTs: interaction.threadTs,
+      teamId: interaction.teamId,
+    }),
+  );
+  const response = await fetch(`https://slack.com/api/chat.update`, {
+    method: `POST`,
+    headers: {
+      authorization: `Bearer ${token}`,
+      "content-type": `application/json; charset=utf-8`,
+    },
+    body: JSON.stringify({
+      channel: interaction.channelId,
+      ts: action.messageTs,
+      blocks,
+      text: `Answered: ${answerLabel}`,
+    }),
+  });
+  if (!response.ok) throw Error(`Slack chat.update returned HTTP ${response.status}`);
+}
+
+async function updateAnsweredFreeformCard(input) {
+  const blocks = buildAnsweredBlocks({
+    promptBlock: undefined,
+    answerLabel: input.answerLabel,
+    userId: input.userId,
+  });
+  const token = await resolveSlackBotToken(
+    input.deps.config.credentials?.botToken,
+    createSlackBotTokenContext({
+      channelId: input.channelId,
+      threadTs: input.threadTs,
+      teamId: input.teamId,
+    }),
+  );
+  const response = await fetch(`https://slack.com/api/chat.update`, {
+    method: `POST`,
+    headers: {
+      authorization: `Bearer ${token}`,
+      "content-type": `application/json; charset=utf-8`,
+    },
+    body: JSON.stringify({
+      channel: input.channelId,
+      ts: input.messageTs,
+      blocks,
+      text: `Answered: ${input.answerLabel}`,
+    }),
+  });
+  if (!response.ok) throw Error(`Slack chat.update returned HTTP ${response.status}`);
+}
+
+export { handleInteractionPost, parseBlockActionsPayload };
