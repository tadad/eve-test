+import { createLogger, logError } from "#internal/logging.js";
+import { isCardElement } from "#compiled/chat/index.js";
+import { encodeSlackApiBody } from "#public/channels/slack/api-encoding.js";
+import { cardToBlocks, cardToFallbackText } from "#public/channels/slack/blocks.js";
+import {
+  gfmToSlackMrkdwn,
+  rewriteBareMentions,
+  slackMrkdwnToGfm,
+} from "#public/channels/slack/mrkdwn.js";
+
+const log = createLogger(`slack.api`);
+
+function slackContinuationToken(channelId, threadTs) {
+  return `${channelId}:${threadTs}`;
+}
+
+function createSlackBotTokenContext(input) {
+  return {
+    channelId: input.channelId,
+    threadTs: input.threadTs,
+    teamId: input.teamId,
+  };
+}
+
+async function resolveSlackBotToken(token, context) {
+  const resolved = token ?? process.env.SLACK_BOT_TOKEN;
+  if (!resolved) throw Error(`SLACK_BOT_TOKEN is required.`);
+  return typeof resolved === `function` ? await resolved(context) : resolved;
+}
+
+async function callSlackApi(input) {
+  const token = await resolveSlackBotToken(input.botToken, input.context);
+  const body = encodeSlackApiBody(input.body);
+  return (
+    await fetch(`https://slack.com/api/${input.operation}`, {
+      method: `POST`,
+      headers: {
+        authorization: `Bearer ${token}`,
+        "content-type": body.contentType,
+      },
+      body: body.body,
+    })
+  ).json();
+}
+
+function createSlackRequester(botToken, getContext) {
+  return (operation, body) =>
+    callSlackApi({
+      botToken,
+      operation,
+      body,
+      context: getContext(),
+    });
+}
+
+function buildSlackBinding(input) {
+  const recentMessages = [];
+  let threadTs = input.threadTs;
+  const request = createSlackRequester(input.botToken, () =>
+    createSlackBotTokenContext({ ...input, threadTs }),
+  );
+
+  function handleMessageTs(messageTs) {
+    if (!threadTs && messageTs !== threadTs) {
+      threadTs = messageTs;
+      input.onThreadTsChanged?.(messageTs);
+    }
+  }
+
+  async function uploadFiles(files, options) {
+    if (files.length === 0) return { fileIds: [], raw: { ok: true } };
+
+    const channelId = options?.channelId ?? input.channelId;
+    const uploadThreadTs = options?.threadTs ?? threadTs;
+    const context = createSlackBotTokenContext({
+      ...input,
+      channelId,
+      threadTs: uploadThreadTs,
+    });
+    const token = await resolveSlackBotToken(input.botToken, context);
+    const fileIds = [];
+
+    for (const file of files) {
+      const bytes = await readFileBytes(file.data);
+      const uploadUrlResponse = await callSlackApi({
+        botToken: input.botToken,
+        operation: `files.getUploadURLExternal`,
+        body: { filename: file.filename, length: bytes.byteLength },
+        context,
+      });
+
+      if (
+        uploadUrlResponse.ok !== true ||
+        typeof uploadUrlResponse.upload_url !== `string` ||
+        typeof uploadUrlResponse.file_id !== `string`
+      ) {
+        throw Error(
+          `Slack files.getUploadURLExternal failed: ${
+            uploadUrlResponse.error ?? `unknown_error`
+          }`,
+        );
+      }
+
+      const uploadResponse = await fetch(uploadUrlResponse.upload_url, {
+        method: `POST`,
+        headers: {
+          authorization: `Bearer ${token}`,
+          "content-type": `application/octet-stream`,
+        },
+        body: bytes,
+      });
+
+      if (!uploadResponse.ok) {
+        throw Error(
+          `Slack upload POST returned HTTP ${uploadResponse.status} for ${file.filename}.`,
+        );
+      }
+
+      fileIds.push(uploadUrlResponse.file_id);
+    }
+
+    const completeBody = {
+      files: files.map((file, index) => ({ id: fileIds[index], title: file.filename })),
+    };
+    if (channelId) completeBody.channel_id = channelId;
+    if (uploadThreadTs) completeBody.thread_ts = uploadThreadTs;
+    if (options?.initialComment) completeBody.initial_comment = options.initialComment;
+
+    const completeResponse = await callSlackApi({
+      botToken: input.botToken,
+      operation: `files.completeUploadExternal`,
+      body: completeBody,
+      context,
+    });
+
+    if (completeResponse.ok !== true) {
+      throw Error(
+        `Slack files.completeUploadExternal failed: ${
+          completeResponse.error ?? `unknown_error`
+        }`,
+      );
+    }
+
+    return { fileIds, raw: completeResponse };
+  }
+
+  return {
+    thread: {
+      recentMessages,
+      async post(message) {
+        const normalized = normalizePostInput(message);
+        const files = normalized.files ?? [];
+        const hasStructuredMessage = `blocks` in normalized || `card` in normalized;
+
+        if (files.length > 0 && !hasStructuredMessage) {
+          const upload = await uploadFiles(files, {
+            initialComment:
+              `markdown` in normalized
+                ? rewriteBareMentions(gfmToSlackMrkdwn(normalized.markdown))
+                : `text` in normalized
+                  ? rewriteBareMentions(normalized.text)
